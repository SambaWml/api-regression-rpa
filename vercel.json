{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "framework": "vite",
      "entrypoint": "frontend",
      "routePrefix": "/"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  },
  "rewrites": [
    { "source": "/((?!_/).*\\..+)", "destination": "/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
